{
  "$schema": "../../schemas/gnustep-packager.schema.json",
  "schemaVersion": 1,
  "profiles": [
    "gnustep-gui"
  ],
  "package": {
    "id": "com.example.SampleGNUstepApp",
    "name": "SampleGNUstepApp",
    "displayName": "Sample GNUstep App",
    "version": "0.1.0",
    "manufacturer": "Example Org",
    "summary": "Reference manifest for a packaged GNUstep desktop application.",
    "license": "MIT",
    "homepage": "https://example.invalid/sample-gnustep-app"
  },
  "pipeline": {
    "workingDirectory": ".",
    "shell": {
      "kind": "pwsh",
      "bootstrapCommands": [],
      "environment": {
        "GP_FIXTURE_MODE": "1"
      }
    },
    "build": {
      "command": "./scripts/build-fixture.ps1 -OutRoot out/build"
    },
    "stage": {
      "command": "./scripts/stage-fixture.ps1 -StageRoot dist/stage",
      "outputRoot": "dist/stage"
    }
  },
  "payload": {
    "layoutVersion": 1,
    "stageRoot": "dist/stage",
    "appRoot": "app",
    "runtimeRoot": "runtime",
    "runtimeSeedPaths": [
      "runtime/bin/defaults.exe"
    ]
  },
  "launch": {
    "entryRelativePath": "app/SampleGNUstepApp.app/SampleGNUstepApp.exe",
    "workingDirectory": ".",
    "arguments": [],
    "env": {
      "GSTheme": {
        "value": "WinUXTheme",
        "policy": "ifUnset"
      }
    }
  },
  "packagedDefaults": {
    "defaultTheme": "WinUXTheme",
    "appDomain": {
      "values": {
        "SampleFirstRunComplete": true,
        "SamplePreferredWidth": 800,
        "SampleWelcomeText": "Packaged sample"
      }
    }
  },
  "outputs": {
    "root": "dist",
    "packageRoot": "dist/packages",
    "logRoot": "dist/logs",
    "tempRoot": "dist/tmp",
    "validationRoot": "dist/validation"
  },
  "validation": {
    "smoke": {
      "enabled": true,
      "kind": "staged-layout",
      "requiredPaths": [
        "metadata/icons/sample-icon.txt",
        "runtime/config/theme.conf"
      ],
      "timeoutSeconds": 30
    },
    "logs": {
      "retainOnSuccess": true
    },
    "packageContract": {
      "requiredContent": [
        {
          "kind": "notice-report"
        },
        {
          "kind": "bundled-theme",
          "name": "WinUXTheme"
        },
        {
          "kind": "metadata-file",
          "path": "metadata/icons/sample-icon.txt"
        }
      ]
    },
    "installedResult": {
      "requiredContent": [
        {
          "kind": "notice-report"
        },
        {
          "kind": "bundled-theme",
          "name": "WinUXTheme"
        }
      ],
      "requiredPaths": [
        "metadata/icons/sample-icon.txt"
      ]
    }
  },
  "integrations": {
    "shortcutName": "Sample GNUstep App",
    "fileAssociations": [
      {
        "kind": "extension",
        "value": ".sample",
        "description": "Sample GNUstep document"
      }
    ]
  },
  "compliance": {
    "runtimeNotices": [
      {
        "name": "SampleGNUstepApp",
        "version": "0.1.0",
        "license": "MIT",
        "source": "Reference fixture application payload",
        "homepage": "https://example.invalid/sample-gnustep-app",
        "stageRelativePath": "metadata/licenses/SampleGNUstepApp.txt"
      },
      {
        "name": "GNUstep Runtime Seed",
        "license": "LGPL-2.1-or-later",
        "source": "Fixture runtime payload for packaging and validation tests",
        "stageRelativePath": "metadata/licenses/GNUstep-runtime.txt"
      }
    ]
  },
  "backends": {
    "msi": {
      "enabled": true,
      "upgradeCode": "11111111-1111-1111-1111-111111111111",
      "installScope": "perUser",
      "productName": "Sample GNUstep App",
      "shortcutName": "Sample GNUstep App",
      "installDirectoryName": "SampleGNUstepApp",
      "launcherFileName": "SampleGNUstepApp.exe"
    },
    "appimage": {
      "enabled": false,
      "desktopEntryName": "sample-gnustep-app.desktop"
    }
  }
}
