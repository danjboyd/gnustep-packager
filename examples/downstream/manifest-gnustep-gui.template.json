{
  "$schema": "../../schemas/gnustep-packager.schema.json",
  "schemaVersion": 1,
  "profiles": [
    "gnustep-gui"
  ],
  "package": {
    "id": "com.example.MyGNUstepApp",
    "name": "MyGNUstepApp",
    "displayName": "My GNUstep App",
    "version": "0.1.0",
    "manufacturer": "Example Org",
    "license": "MIT"
  },
  "pipeline": {
    "workingDirectory": ".",
    "shell": {
      "kind": "pwsh",
      "bootstrapCommands": [],
      "environment": {}
    },
    "build": {
      "command": "./scripts/build.ps1"
    },
    "stage": {
      "command": "./scripts/stage.ps1 -StageRoot dist/stage",
      "outputRoot": "dist/stage"
    }
  },
  "payload": {
    "layoutVersion": 1,
    "stageRoot": "dist/stage",
    "appRoot": "app",
    "runtimeRoot": "runtime"
  },
  "launch": {
    "entryRelativePath": "app/MyGNUstepApp.app/MyGNUstepApp.exe",
    "workingDirectory": ".",
    "env": {}
  },
  "outputs": {
    "root": "dist",
    "packageRoot": "dist/packages",
    "logRoot": "dist/logs",
    "tempRoot": "dist/tmp",
    "validationRoot": "dist/validation"
  },
  "validation": {
    "smoke": {
      "enabled": true,
      "kind": "staged-layout",
      "requiredPaths": [],
      "timeoutSeconds": 30
    },
    "logs": {
      "retainOnSuccess": true
    }
  },
  "integrations": {
    "shortcutName": "My GNUstep App",
    "fileAssociations": []
  },
  "updates": {
    "enabled": true,
    "provider": "github-release-feed",
    "channel": "stable",
    "minimumCheckIntervalHours": 24,
    "startupDelaySeconds": 15,
    "github": {
      "owner": "example-org",
      "repo": "my-gnustep-app",
      "tagPattern": "v{version}",
      "releaseNotesUrlPattern": "https://github.com/{owner}/{repo}/releases/tag/{tag}"
    }
  },
  "compliance": {
    "runtimeNotices": [
      {
        "name": "GNUstep Runtime",
        "license": "<set-license>",
        "stageRelativePath": "metadata/licenses/gnustep-runtime.txt"
      }
    ]
  },
  "backends": {
    "msi": {
      "enabled": true,
      "upgradeCode": "00000000-0000-0000-0000-000000000000",
      "updates": {
        "feedUrl": "https://example-org.github.io/my-gnustep-app/updates/windows/stable.json"
      }
    },
    "appimage": {
      "enabled": false,
      "desktopEntryName": "my-gnustep-app.desktop",
      "iconRelativePath": "metadata/icons/app.png"
    }
  }
}
