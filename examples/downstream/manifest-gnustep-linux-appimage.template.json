{
  "$schema": "../../schemas/gnustep-packager.schema.json",
  "schemaVersion": 1,
  "profiles": [
    "gnustep-gui"
  ],
  "package": {
    "id": "com.example.MyGNUstepLinuxApp",
    "name": "MyGNUstepLinuxApp",
    "displayName": "My GNUstep Linux App",
    "version": "0.1.0",
    "manufacturer": "Example Org",
    "summary": "Short desktop summary for the AppImage metadata.",
    "license": "MIT",
    "homepage": "https://example.com/my-gnustep-linux-app"
  },
  "pipeline": {
    "workingDirectory": ".",
    "shell": {
      "kind": "bash",
      "bootstrapCommands": [],
      "environment": {}
    },
    "build": {
      "command": "./scripts/build.sh"
    },
    "stage": {
      "command": "./scripts/stage.sh dist/stage",
      "outputRoot": "dist/stage"
    }
  },
  "payload": {
    "layoutVersion": 1,
    "stageRoot": "dist/stage",
    "appRoot": "app",
    "runtimeRoot": "runtime"
  },
  "launch": {
    "entryRelativePath": "app/MyGNUstepLinuxApp.app/MyGNUstepLinuxApp",
    "workingDirectory": "app/MyGNUstepLinuxApp.app",
    "env": {}
  },
  "outputs": {
    "root": "dist",
    "packageRoot": "dist/packages",
    "logRoot": "dist/logs",
    "tempRoot": "dist/tmp",
    "validationRoot": "dist/validation"
  },
  "validation": {
    "smoke": {
      "enabled": true,
      "kind": "staged-layout",
      "requiredPaths": [
        "metadata/icons/app.png"
      ],
      "timeoutSeconds": 30
    },
    "logs": {
      "retainOnSuccess": true
    }
  },
  "integrations": {
    "shortcutName": "My GNUstep Linux App",
    "fileAssociations": []
  },
  "updates": {
    "enabled": true,
    "provider": "github-release-feed",
    "channel": "stable",
    "minimumCheckIntervalHours": 24,
    "startupDelaySeconds": 15,
    "github": {
      "owner": "example-org",
      "repo": "my-gnustep-linux-app",
      "tagPattern": "v{version}",
      "releaseNotesUrlPattern": "https://github.com/{owner}/{repo}/releases/tag/{tag}"
    }
  },
  "compliance": {
    "runtimeNotices": [
      {
        "name": "GNUstep Runtime",
        "license": "<set-license>",
        "stageRelativePath": "metadata/licenses/gnustep-runtime.txt"
      }
    ]
  },
  "backends": {
    "msi": {
      "enabled": false
    },
    "appimage": {
      "enabled": true,
      "desktopEntryName": "my-gnustep-linux-app.desktop",
      "iconRelativePath": "metadata/icons/app.png",
      "updates": {
        "feedUrl": "https://example-org.github.io/my-gnustep-linux-app/updates/linux/stable.json",
        "embedUpdateInformation": true,
        "releaseSelector": "latest"
      },
      "smoke": {
        "mode": "launch-only"
      }
    }
  }
}
