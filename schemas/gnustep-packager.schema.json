{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/gnustep-packager/schemas/gnustep-packager.schema.json",
  "title": "GNUstep Packager Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "package",
    "pipeline",
    "payload",
    "launch",
    "outputs",
    "validation"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "version",
        "manufacturer"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "manufacturer": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "homepage": {
          "type": "string"
        },
        "license": {
          "type": "string"
        }
      }
    },
    "pipeline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workingDirectory",
        "shell",
        "build",
        "stage"
      ],
      "properties": {
        "workingDirectory": {
          "type": "string",
          "minLength": 1
        },
        "shell": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "bootstrapCommands",
            "environment"
          ],
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "pwsh",
                "powershell",
                "bash",
                "sh",
                "msys2-bash"
              ]
            },
            "program": {
              "type": "string"
            },
            "msysRoot": {
              "type": "string"
            },
            "bootstrapCommands": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "environment": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "build": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "command"
          ],
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "stage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "command",
            "outputRoot"
          ],
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            },
            "outputRoot": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "validate": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layoutVersion",
        "stageRoot",
        "appRoot",
        "runtimeRoot"
      ],
      "properties": {
        "layoutVersion": {
          "type": "integer",
          "const": 1
        },
        "stageRoot": {
          "type": "string",
          "minLength": 1
        },
        "appRoot": {
          "type": "string",
          "minLength": 1
        },
        "runtimeRoot": {
          "type": "string",
          "minLength": 1
        },
        "metadataRoot": {
          "type": "string",
          "minLength": 1
        },
        "resourceRoots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "runtimeSeedPaths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "launch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entryRelativePath",
        "workingDirectory"
      ],
      "properties": {
        "entryRelativePath": {
          "type": "string",
          "minLength": 1
        },
        "workingDirectory": {
          "type": "string",
          "minLength": 1
        },
        "arguments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pathPrepend": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "resourceRoots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "packageRoot",
        "logRoot",
        "tempRoot",
        "validationRoot"
      ],
      "properties": {
        "root": {
          "type": "string",
          "minLength": 1
        },
        "packageRoot": {
          "type": "string",
          "minLength": 1
        },
        "logRoot": {
          "type": "string",
          "minLength": 1
        },
        "tempRoot": {
          "type": "string",
          "minLength": 1
        },
        "validationRoot": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "smoke",
        "logs"
      ],
      "properties": {
        "smoke": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "enabled",
            "kind",
            "requiredPaths",
            "timeoutSeconds"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "kind": {
              "type": "string",
              "enum": [
                "staged-layout"
              ]
            },
            "requiredPaths": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "timeoutSeconds": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "logs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "retainOnSuccess"
          ],
          "properties": {
            "retainOnSuccess": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "integrations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "shortcutName": {
          "type": "string",
          "minLength": 1
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fileAssociations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "value"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "extension",
                  "mime"
                ]
              },
              "value": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtimeNotices": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "version": {
                "type": "string"
              },
              "license": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "homepage": {
                "type": "string"
              },
              "stageRelativePath": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "backends": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "msi": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "upgradeCode": {
              "type": "string",
              "pattern": "^[0-9a-fA-F-]{36}$"
            },
            "installScope": {
              "type": "string",
              "enum": [
                "perMachine",
                "perUser"
              ]
            },
            "productName": {
              "type": "string"
            },
            "shortcutName": {
              "type": "string"
            },
            "installDirectoryName": {
              "type": "string"
            },
            "launcherFileName": {
              "type": "string"
            },
            "iconRelativePath": {
              "type": "string"
            },
            "artifactNamePattern": {
              "type": "string"
            },
            "portableArtifactNamePattern": {
              "type": "string"
            },
            "fallbackRuntimeRoot": {
              "type": "string"
            },
            "runtimeSearchRoots": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "wix": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "version": {
                  "type": "string",
                  "minLength": 1
                },
                "downloadUrl": {
                  "type": "string",
                  "minLength": 1
                },
                "toolRoot": {
                  "type": "string",
                  "minLength": 1
                },
                "skipValidation": {
                  "type": "boolean"
                },
                "suppressedIces": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            },
            "signing": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "toolPath": {
                  "type": "string"
                },
                "timestampUrl": {
                  "type": "string"
                },
                "certificateSha1": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                },
                "additionalArguments": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "appimage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "appDirName": {
              "type": "string"
            },
            "desktopEntryName": {
              "type": "string"
            },
            "iconRelativePath": {
              "type": "string"
            },
            "artifactNamePattern": {
              "type": "string"
            },
            "toolRoot": {
              "type": "string"
            },
            "downloadUrl": {
              "type": "string"
            },
            "skipAppStreamValidation": {
              "type": "boolean"
            },
            "smoke": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "mode": {
                  "type": "string",
                  "enum": [
                    "launch-only",
                    "open-file",
                    "custom-arguments",
                    "marker-file"
                  ]
                },
                "arguments": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "environment": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                "documentStageRelativePath": {
                  "type": "string",
                  "minLength": 1
                },
                "startupSeconds": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "mode": {
                        "const": "open-file"
                      }
                    },
                    "required": [
                      "mode"
                    ]
                  },
                  "then": {
                    "required": [
                      "documentStageRelativePath"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    }
  }
}
